{
  "name": "n8n-nodes-prestashop8",
  "version": "2.3.0",
  "description": "Nœud n8n personnalisé pour PrestaShop 8 avec support CRUD complet et conversion XML/JSON automatique",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "prestashop",
    "ecommerce",
    "api"
  ],
  "license": "MIT",
  "homepage": "https://github.com/PPCM/n8n-nodes-prestashop8#readme",
  "author": {
    "name": "PPCM",
    "email": "contact@ppcm.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PPCM/n8n-nodes-prestashop8.git"
  },
  "bugs": {
    "url": "https://github.com/PPCM/n8n-nodes-prestashop8/issues"
  },
  "engines": {
    "node": ">=16.10",
    "pnpm": ">=7.18"
  },
  "packageManager": "pnpm@7.18.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "fetch-schemas": "node scripts/fetch-prestashop-schemas.js",
    "clean": "rm -rf dist",
    "package": "npm run clean && npm run build && npm pack"
  },
  "files": [
    "dist",
    "prestashop8.svg"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PrestaShop8Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PrestaShop8/PrestaShop8.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "axios": "^1.15.0",
    "@types/node": "^24.12.2",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.37.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "globals": "^17.5.0",
    "gulp": "^5.0.1",
    "jest": "^30.3.0",
    "n8n-workflow": "^1.82.0",
    "prettier": "^2.7.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "js2xmlparser": "^5.0.0",
    "xml2js": "^0.6.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "overrides": {
    "lodash": "^4.18.0",
    "minimatch": "^3.1.3",
    "picomatch": "^4.0.4",
    "brace-expansion": "^1.1.13",
    "uuid": "^14.0.0",
    "axios": "^1.15.0",
    "form-data": "^4.0.4",
    "follow-redirects": "^1.16.0"
  }
}
